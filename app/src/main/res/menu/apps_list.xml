<?xml version="1.0" encoding="utf-8"?>
<menu
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="AlwaysShowAction">

    <item
        android:id="@+id/action_search"
        android:icon="@drawable/search_icon_control_normal_24dp"
        android:orderInCategory="100"
        android:title="@string/search"
        app:actionViewClass="me.zhanghai.android.files.ui.FixQueryChangeSearchView"
        app:showAsAction="always|collapseActionView" />

    <item
        android:id="@+id/action_sort"
        android:icon="@drawable/sort_icon_control_normal_24dp"
        android:orderInCategory="100"
        android:title="@string/apps_list_action_sort"
        app:showAsAction="always">
        <menu>
            <group
                android:id="@+id/group_sort"
                android:checkableBehavior="single">
                <item
                    android:id="@+id/action_sort_by_name"
                    android:title="@string/apps_list_action_sort_by_name" />
                <item
                    android:id="@+id/action_sort_by_package_name"
                    android:title="@string/apps_list_action_sort_by_package_name" />
                <item
                    android:id="@+id/action_sort_by_install_time"
                    android:title="@string/apps_list_action_sort_by_install_time" />
                <item
                    android:id="@+id/action_sort_order_ascending"
                    android:checkable="true"
                    android:title="@string/apps_list_action_sort_order_ascending" />
            </group>
        </menu>
    </item>
</menu>